# Copy this file to .env, fill in the key, then run 9xf.
# The harness reads .env from the current working directory and the run folder.
# You can also export it manually before running 9xf:
#   cp .env.example .env
#   set -a; source .env; set +a
#
# OpenRouter is the default LLM provider. Get a key at openrouter.ai.
# The free auto-routing model (openrouter/openrouter/free) is used by default.
# Pin specific models with --model openrouter/anthropic/claude-3.5-sonnet, etc.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://127.0.0.1:8000
OPENROUTER_APP_TITLE=9xf Loops
OPENROUTER_REASONING=false

# NVIDIA cloud inference is used by nvidia/<provider>/<model> configs, including:
#   nvidia/moonshotai/kimi-k2.6
#   nvidia/qwen/qwen3.5-122b-a10b
NVIDIA_API_KEY=nvapi-your-key-here

# Mistral cloud inference is used by mistral/<model> configs, including:
#   mistral/mistral-small-2603
MISTRAL_API_KEY=your-mistral-key-here

# Run the cloud benchmark:
#   python3 -m ninexf bench run thesis --out bench_out
